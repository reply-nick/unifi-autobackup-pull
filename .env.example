# Cron schedule: minute hour day month weekday
# Examples:
#   Daily at 3:00 AM:         0 3 * * *
#   Every 6 hours:            0 */6 * * *
#   Every Sunday at 2:00 AM:  0 2 * * 0
CRON_SCHEDULE=0 3 * * *

# UniFi OS host
UNIFI_HOST=192.168.1.1

# SSH user on UniFi OS
UNIFI_USER=root

# Path to autobackup on UniFi OS
REMOTE_DIR=/data/autobackup

# Samba (optional)
COPY_TO_SAMBA=false
SAMBA_SHARE=
SAMBA_USER=
SAMBA_PASSWORD=
SAMBA_DOMAIN=
